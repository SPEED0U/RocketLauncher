{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RocketLauncher",
  "version": "1.2.0",
  "identifier": "dev.speedou.rocket-launcher",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RocketLauncher",
        "label": "main",
        "width": 1280,
        "height": 720,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#09090bff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    }
  }
}
